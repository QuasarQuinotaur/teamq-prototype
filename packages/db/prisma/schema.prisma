generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Employee {
  id          Int        @id @default(autoincrement())
  auth0Id     String?    @unique
  email       String     @unique
  firstName   String
  lastName    String
  dateOfBirth DateTime
  jobPosition String
  userPhoto   UserPhoto?

  contentsOwned Content[] @relation("ownedContents") // relationship list

  contentsFavorited Content[] @relation("Favorites") // implicit many to many (dont need to make table yippee)

  createdRequests  ServiceRequest[] @relation("OwnedRequests")
  assignedRequests ServiceRequest[] @relation("EmployeeRequests")

  notifications  Notification[]  @relation("NotificationEmployees")
  contentChecked Content[]       @relation("CheckedOutContent")

  recentViews RecentContentView[]
  tagsCreated    Tag[]
  contentReviews ContentReview[]

  // added user setting the employee
  userSettings UserSettings?
}

enum RolePermission {
    ADMIN
    EMPLOYEE
}

model Role {
    id              Int                 @id @default(autoincrement())
    key             String              @unique
    name            String              
    permission      RolePermission      @default(EMPLOYEE)
}

model Content {
  id                 Int              @id @default(autoincrement())
  title              String
  filePath           String? // path in Supabase bucket
  fileSize           Int?
  jobPositions       String[] // scalar list
  contentType        String
  dateAdded          DateTime         @default(now())
  dateUpdated        DateTime         @updatedAt
  reviews            ContentReview[]
  expirationDate     DateTime
  employeesFavorited Employee[]       @relation("Favorites") // one content can have many favorites from dif people
  ownerId            Int // TODO be able to update owner (only owner + admin) in front end too :( - Kylie still needs to do this
  owner              Employee         @relation("ownedContents", fields: [ownerId], references: [id])
  serviceRequests    ServiceRequest[] @relation("ContentRequests")
  notifications      Notification[]   @relation("NotificationContents")

  isCheckedOut   Boolean   @default(false)
  checkedOutOn   DateTime?
  checkedOutById Int?
  checkedOutBy   Employee? @relation("CheckedOutContent", fields: [checkedOutById], references: [id])

  hasBeenNotifiedExpiringSoon   Boolean     @default(false)
  hasBeenNotifiedOfExpiration   Boolean     @default(false)

  recentViews RecentContentView[]
  tags ContentTag[]

  isTutorial Boolean @default(false)

  @@index([isTutorial, ownerId])
  @@index([ownerId])
  @@index([contentType])
  @@index([expirationDate])
  @@index([isCheckedOut, checkedOutOn])
}

// Service Request:

model ServiceRequest {
  id          Int       @id @default(autoincrement())
  title       String?
  description String?
  dateCreated DateTime  @default(now())
  dateDue     DateTime?
  priority    String?
  status      String    @default("to-do") // allowed: to-do | done (DB CHECK)

  ownerId Int
  owner   Employee @relation("OwnedRequests", fields: [ownerId], references: [id])

  employees Employee[] @relation("EmployeeRequests")
  contents  Content[]  @relation("ContentRequests")
}

model Notification {
  id                  Int      @id @default(autoincrement())
  type                String
  dateSent            DateTime @default(now())
  customMsg           String?
  employeeWasNotified Boolean  @default(false)

  dateRead DateTime?

  employeeNotifiedID Int

  employeeNotified Employee  @relation("NotificationEmployees", fields: [employeeNotifiedID], references: [id])
  contentsUsed     Content[] @relation("NotificationContents") //"contents a part of notification (can be none)"

  @@index([employeeNotifiedID, employeeWasNotified]) // index for O(log(n)) time
}

model UserPhoto {
  id      Int      @id @default(autoincrement())
  ownerId Int      @unique
  path    String
  owner   Employee @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}

model RecentContentView {
  employeeId   Int
  contentId    Int
  lastViewedAt DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  content  Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@id([employeeId, contentId])
  @@index([employeeId, lastViewedAt])
}

model Tag {
  id      Int      @id @default(autoincrement())
  ownerId Int
  tagName String
  color   String   @default("#ff0000")
  owner   Employee @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  contents ContentTag[]

  @@unique([ownerId, tagName])
  @@index([tagName])
}

model ContentTag {
  contentId Int
  tagId     Int

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contentId, tagId])
  @@index([tagId])
}

model UserSettings {
  id          Int      @id @default(autoincrement())
  ownerId     Int      @unique
  theme       String   @default("Hanover Blue")
  iconSize    String   @default("Medium")
  textSize    String   @default("Medium")
  tagsEnabled Boolean  @default(true)
  listEnabled Boolean  @default(false)
  owner       Employee @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}

// Date Review:
model ContentReview {
  id   Int      @id @default(autoincrement())
  date DateTime

  contentId  Int
  employeeId Int? // optional specifiy who needs to review it

  status   String  @default("pending") // pending | done | skipped
  stepName String //  "Watch video", "Complete quiz"
  note     String?

  createdAt   DateTime  @default(now())
  completedAt DateTime?

  content  Content   @relation(fields: [contentId], references: [id], onDelete: Cascade)
  employee Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  @@index([contentId])
  @@index([employeeId])
  @@index([status])
}
