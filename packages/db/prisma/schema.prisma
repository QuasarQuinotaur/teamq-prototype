generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Employee {
  id          Int       @id @default(autoincrement())
  auth0Id     String?   @unique
  email       String    @unique
  firstName   String
  lastName    String
  dateOfBirth DateTime
  jobPosition String
  contents    Content[]

  createdRequests  ServiceRequest[] @relation("CreatedRequests")
  assignedRequests ServiceRequest[] @relation("AssignedRequests")
}

model Content {
  id             Int      @id @default(autoincrement())
  title          String
  link           String
  ownerName      String
  jobPosition    String
  contentType    String
  status         String
  dateAdded      DateTime @default(now())
  dateUpdated    DateTime @updatedAt
  expirationDate DateTime
  ownerId        Int
  owner          Employee @relation(fields: [ownerId], references: [id])
}

model ServiceRequest {
  id                          Int                       @id @default(autoincrement())
  description                 String
  dateCreated                 DateTime                  @default(now())
  dateDue                     DateTime
  priority                    String
  status                      String                    @default("to-do")
  serviceRequestToEmployeesID Int
  serviceRequestToEmployees   ServiceRequestToEmployees @relation("", fields: [serviceRequestToEmployeesID], references: [id])
  serviceRequestToContentsID  Int
  serviceRequestToContents    ServiceRequestToContents  @relation("", fields: [serviceRequestToContentsID], references: [id])
}

model ServiceRequestToEmployees {
  id          Int            @id @default(autoincrement())
  serviceID   Int
  service     ServiceRequest @relation("", fields: [serviceID], references: [id])
  requestedID Int
  requested   Employee       @relation("", fields: [requesteeID], references: [id])
}

model ServiceRequestToContents {
  id        Int      @id @default(autoincrement())
  serviceID Int
  service   Employee @relation("AssignedRequests", fields: [serviceID], references: [id])
  contentID Int
  Content   Content  @relation("", fields: [contentID], references: [id])
}

model Favorites {
  id         Int      @id @default(autoincrement())
  employeeID Int
  employee   Employee @relation("", fields: [employeeID], references: [id])
  contentID  Int
  Content    Content  @relation("", fields: [contentID], references: [id])
}
