generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Employee {
  id          Int       @id @default(autoincrement())
  auth0Id     String?   @unique
  email       String    @unique
  firstName   String
  lastName    String
  dateOfBirth DateTime
  jobPosition String
  contents    Content[]

  createdRequests  ServiceRequest[] @relation("CreatedRequests")
  assignedRequests ServiceRequest[] @relation("AssignedRequests")
}

model Content {
  id             Int      @id @default(autoincrement())
  title          String
  link           String
  ownerName      String
  jobPosition    String
  contentType    String
  status         String
  dateAdded      DateTime @default(now())
  dateUpdated    DateTime @updatedAt
  expirationDate DateTime
  ownerId        Int
  owner          Employee @relation(fields: [ownerId], references: [id])
}

model ServiceRequest {
  id          Int      @id @default(autoincrement())
  type        String
  creatorID   Int
  creator     Employee @relation("CreatedRequests", fields: [creatorID], references: [id])
  requesteeID Int
  requestee   Employee @relation("AssignedRequests", fields: [requesteeID], references: [id])
}
