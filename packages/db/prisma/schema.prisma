generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Employee {
  id                                                  Int              @id @default(autoincrement())
  auth0Id                                             String?          @unique
  dateOfBirth                                         DateTime
  email                                               String           @unique
  firstName                                           String
  jobPosition                                         String
  lastName                                            String
  username                                            String?
  password                                            String?
  userPhoto                                           UserPhoto?
  contents                                            Content[]
  createdRequests                                     ServiceRequest[] @relation("CreatedRequests")
  ServiceRequest_ServiceRequest_requesteeIDToEmployee ServiceRequest[] @relation("ServiceRequest_requesteeIDToEmployee")
}

model Content {
  id             Int      @id @default(autoincrement())
  dateAdded      DateTime @default(now())
  dateUpdated    DateTime @updatedAt
  ownerId        Int
  title          String
  contentType    String
  expirationDate DateTime
  jobPosition    String
  link           String
  ownerName      String
  status         String
  owner          Employee @relation(fields: [ownerId], references: [id])
}

model ServiceRequest {
  id                                            Int      @id @default(autoincrement())
  type                                          String
  creatorID                                     Int
  requesteeID                                   Int
  creator                                       Employee @relation("CreatedRequests", fields: [creatorID], references: [id])
  Employee_ServiceRequest_requesteeIDToEmployee Employee @relation("ServiceRequest_requesteeIDToEmployee", fields: [requesteeID], references: [id])
}

model UserPhoto {
  id      Int      @id @default(autoincrement())
  ownerId Int      @unique
  path    String
  owner   Employee @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}
