generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model Employee {
  id          Int      @id @default(autoincrement())
  auth0Id     String?  @unique
  email       String   @unique
  firstName   String
  lastName    String
  dateOfBirth DateTime
  jobPosition String
  /** Set true after the guided document tutorial has been presented (auto or Help). */
  documentTutorialShown Boolean    @default(false)
  userPhoto             UserPhoto?

  contentsOwned     Content[] @relation("ownedContents") // relationship list
  contentsFavorited Content[] @relation("Favorites") // implicit many to many (dont need to make table yippee)

  createdWorkflows ServiceRequestWorkflow[] @relation("OwnedWorkflows")
  assignedStages   ServiceRequestStage[]    @relation("StageAssignees")

  notifications     Notification[]      @relation("NotificationEmployees")
  contentChecked    Content[]           @relation("CheckedOutContent")
  tagsCreated       Tag[]
  contentReviews    ContentReview[]
  RecentContentView RecentContentView[]

  // added user setting the employee
  userSettings UserSettings?

  deletedContentLogs DeletedContentLog[]
  activityLogs       ActivityLog[]
}

model Content {
  id       Int     @id @default(autoincrement())
  title    String
  filePath String? // path in Supabase bucket
  /** Client-generated preview image path in Storage (same bucket conventions as filePath). */
  thumbnailPath      String?
  fileSize           Int?
  jobPositions       String[]
  contentType        String
  dateAdded          DateTime        @default(now())
  dateUpdated        DateTime        @updatedAt
  reviews            ContentReview[]
  expirationDate     DateTime
  employeesFavorited Employee[]      @relation("Favorites") // one content can have many favorites from dif people

  ownerId              Int
  owner                Employee              @relation("ownedContents", fields: [ownerId], references: [id])
  serviceRequestStages ServiceRequestStage[] @relation("StageContents")
  notifications        Notification[]        @relation("NotificationContents")

  isCheckedOut   Boolean   @default(false)
  checkedOutOn   DateTime?
  checkedOutById Int?
  checkedOutBy   Employee? @relation("CheckedOutContent", fields: [checkedOutById], references: [id])

  tags                        ContentTag[]
  aiSummary                   String?      @db.Text
  hasBeenNotifiedExpiringSoon Boolean      @default(false)
  hasBeenNotifiedOfExpiration Boolean      @default(false)

  dateReview        DateTime?
  RecentContentView RecentContentView[]

  viewCount     Int @default(0)
  downloadCount Int @default(0)

  isTutorial Boolean @default(false)

  activityLogs ActivityLog[]

  @@index([isTutorial, ownerId])
  @@index([ownerId])
  @@index([contentType])
  @@index([expirationDate])
  @@index([isCheckedOut, checkedOutOn])
}

model ServiceRequestWorkflow {
  id          Int                   @id @default(autoincrement())
  dateCreated DateTime              @default(now())
  title       String?
  ownerId     Int
  owner       Employee              @relation("OwnedWorkflows", fields: [ownerId], references: [id])
  stages      ServiceRequestStage[]

  @@index([ownerId])
}

model ServiceRequestStage {
  id          Int                    @id @default(autoincrement())
  workflowId  Int
  stageOrder  Int
  dateCreated DateTime               @default(now())
  dateDue     DateTime?
  description String?
  priority    String?
  status      String                 @default("to-do")
  title       String?
  workflow    ServiceRequestWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  contents    Content[]              @relation("StageContents")
  employees   Employee[]             @relation("StageAssignees")

  @@unique([workflowId, stageOrder])
  @@index([workflowId])
}

model Notification {
  id                  Int       @id @default(autoincrement())
  type                String
  dateSent            DateTime  @default(now())
  dateRead            DateTime?
  employeeNotifiedID  Int
  employeeWasNotified Boolean   @default(false)
  customMsg           String?
  employeeNotified    Employee  @relation("NotificationEmployees", fields: [employeeNotifiedID], references: [id])
  contentsUsed        Content[] @relation("NotificationContents")

  @@index([employeeNotifiedID, employeeWasNotified])
}

model UserPhoto {
  id      Int      @id @default(autoincrement())
  ownerId Int      @unique
  path    String
  owner   Employee @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}

model Tag {
  id       Int          @id @default(autoincrement())
  ownerId  Int
  tagName  String
  color    String       @default("#ff0000")
  contents ContentTag[]
  owner    Employee     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  isGlobal Boolean      @default(false)

  @@unique([ownerId, tagName])
  @@index([tagName])
}

model ContentTag {
  contentId Int
  tagId     Int
  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contentId, tagId])
  @@index([tagId])
}

model UserSettings {
  id          Int      @id @default(autoincrement())
  ownerId     Int      @unique
  theme       String   @default("Hanover Blue")
  iconSize    String   @default("Medium")
  textSize    String   @default("Medium")
  tagsEnabled Boolean  @default(true)
  listEnabled Boolean  @default(false)
  owner       Employee @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}

// Date Review:
model ContentReview {
  id   Int      @id @default(autoincrement())
  date DateTime

  contentId  Int
  employeeId Int? // optional specifiy who needs to review it

  status   String  @default("pending") // pending | done | skipped
  stepName String //  "Watch video", "Complete quiz"
  note     String?

  createdAt       DateTime  @default(now())
  completedAt     DateTime?
  dueSoonNotified Boolean   @default(false)
  expiredNotified Boolean   @default(false)

  content  Content   @relation(fields: [contentId], references: [id], onDelete: Cascade)
  employee Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  @@index([contentId])
  @@index([employeeId])
  @@index([status])
}

model RecentContentView {
  employeeId   Int
  contentId    Int
  lastViewedAt DateTime @default(now())
  Content      Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  Employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@id([employeeId, contentId])
  @@index([employeeId, lastViewedAt])
}

model Role {
  id   Int    @id @default(autoincrement())
  key  String @unique
  name String

  // 0 or less - Employee
  // 1+ - Admin
  permissionLevel Int @default(0)
}

model DeletedContentLog {
  id          Int       @id @default(autoincrement())
  contentId   Int
  title       String
  contentType String
  deletedAt   DateTime  @default(now())
  deletedById Int?
  deletedBy   Employee? @relation(fields: [deletedById], references: [id], onDelete: SetNull)

  @@index([deletedAt])
  @@index([deletedById])
}
model ActivityLog {
  id          Int      @id @default(autoincrement())
  employeeId  Int
  contentId   Int?
  type        String
  dateCreated DateTime @default(now())

  contentTitle String?
  contentType  String?

  employee Employee @relation(fields: [employeeId], references: [id])
  content  Content? @relation(fields: [contentId], references: [id])
}

