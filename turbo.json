{
	"$schema": "https://turbo.build/schema.json",
	"globalEnv": ["DATABASE_URL"],
	"tasks": {
		"db:generate": {
			"cache": true
		},
		"dev": {
			"dependsOn": ["^db:generate"],
			"cache": false,
			"persistent": true
		},
		"build": {
			"dependsOn": ["^db:generate"],
			"outputs": ["dist/**", ".vite/**"]
		},
		"start": {
			"cache": false,
			"persistent": true
		}
	}
}